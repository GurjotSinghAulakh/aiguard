{
  "name": "aiguard",
  "displayName": "AIGuard — AI Code Quality Scanner",
  "description": "Real-time detection of AI-generated code issues: shallow error handling, hardcoded secrets, prompt injection, and more.",
  "version": "0.5.0",
  "publisher": "gurjotsinghaulakh",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/GurjotSinghAulakh/aiguard"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "code quality",
    "linter",
    "security",
    "prompt injection",
    "static analysis"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "AIGuard",
      "properties": {
        "aiguard.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable AIGuard diagnostics"
        },
        "aiguard.executablePath": {
          "type": "string",
          "default": "aiguard",
          "description": "Path to the aiguard executable"
        },
        "aiguard.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run AIGuard on file save"
        },
        "aiguard.runOnType": {
          "type": "boolean",
          "default": false,
          "description": "Run AIGuard as you type (may be slow on large files)"
        },
        "aiguard.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to .aiguard.yml config file"
        },
        "aiguard.failUnder": {
          "type": "number",
          "default": 0,
          "description": "Show warning if score is below this threshold"
        }
      }
    },
    "commands": [
      {
        "command": "aiguard.scan",
        "title": "AIGuard: Scan Current File"
      },
      {
        "command": "aiguard.scanWorkspace",
        "title": "AIGuard: Scan Workspace"
      },
      {
        "command": "aiguard.fix",
        "title": "AIGuard: Auto-Fix Current File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
